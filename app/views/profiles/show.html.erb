<% full_name = [@user.first_name, @user.last_name].compact.join(" ").presence || @user.email %>
<% initials = if @user.first_name.present? || @user.last_name.present?
                [@user.first_name, @user.last_name].map { |name| name.to_s.first }.join.upcase
              else
                @user.email.first.upcase
              end %>

<div class="space-y-6">
  <header class="rounded-2xl border border-gray-800 bg-gray-800/60 p-6">
    <div class="flex flex-wrap items-center justify-between gap-5">
      <div class="flex items-center gap-4">
        <div class="flex h-20 w-20 items-center justify-center rounded-full bg-indigo-600 text-3xl font-bold text-white shadow-lg shadow-indigo-950/70">
          <%= initials %>
        </div>
        <div>
          <h1 class="text-3xl font-bold text-white" style="font-family: 'Playfair Display', serif;"><%= full_name %></h1>
          <p class="mt-1 text-sm text-gray-300"><%= @user.email %></p>
          <span class="mt-3 inline-flex rounded-full border px-2.5 py-1 text-xs font-semibold uppercase tracking-wide <%= role_badge_class(@user.role) %>">
            <%= @user.role.humanize %>
          </span>
        </div>
      </div>
      <%= link_to "Edit profile", edit_profile_path, class: "inline-flex rounded-lg border border-gray-700 bg-gray-900/70 px-4 py-2 text-sm font-medium text-gray-200 transition hover:bg-gray-700/80" %>
    </div>
  </header>

  <section class="grid gap-6 lg:grid-cols-3">
    <div class="space-y-6 lg:col-span-2">
      <article class="rounded-2xl border border-gray-800 bg-gray-800/50 p-5">
        <h2 class="mb-4 text-lg font-semibold text-white">About</h2>
        <dl class="grid gap-4 text-sm sm:grid-cols-2">
          <div class="rounded-xl border border-gray-700 bg-gray-900/60 p-3">
            <dt class="text-xs uppercase tracking-[0.15em] text-gray-400">Email</dt>
            <dd class="mt-1 font-medium text-gray-100"><%= @user.email %></dd>
          </div>
          <div class="rounded-xl border border-gray-700 bg-gray-900/60 p-3">
            <dt class="text-xs uppercase tracking-[0.15em] text-gray-400">Role</dt>
            <dd class="mt-1 font-medium text-gray-100"><%= @user.role.humanize %></dd>
          </div>
          <div class="rounded-xl border border-gray-700 bg-gray-900/60 p-3 sm:col-span-2">
            <dt class="text-xs uppercase tracking-[0.15em] text-gray-400">Member since</dt>
            <dd class="mt-1 font-medium text-gray-100"><%= l(@user.created_at, format: :long) %></dd>
          </div>
        </dl>
      </article>

      <article class="rounded-2xl border border-gray-800 bg-gray-800/50 p-5">
        <h2 class="mb-4 text-lg font-semibold text-white">Projects</h2>
        <% if @project_memberships.any? %>
          <div class="space-y-2">
            <% @project_memberships.each do |membership| %>
              <div class="rounded-xl border border-gray-700 bg-gray-900/60 p-3">
                <div class="flex flex-wrap items-center justify-between gap-2">
                  <div>
                    <p class="font-medium text-gray-100"><%= membership.project.name %></p>
                    <p class="text-xs uppercase tracking-wide text-gray-400"><%= membership.project.key %></p>
                  </div>
                  <span class="rounded-full border border-gray-600 bg-gray-800 px-2.5 py-1 text-xs uppercase tracking-wide text-gray-200">
                    <%= membership.role.humanize %>
                  </span>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-400">No project memberships yet.</p>
        <% end %>
      </article>

      <article class="rounded-2xl border border-gray-800 bg-gray-800/50 p-5">
        <h2 class="mb-4 text-lg font-semibold text-white">Recent Activity</h2>
        <% if @recent_activity_logs.any? %>
          <div class="space-y-2">
            <% @recent_activity_logs.each_with_index do |activity_log, index| %>
              <% row_background = index.even? ? "bg-gray-900/50" : "bg-gray-900/70" %>
              <article class="relative rounded-xl border border-gray-700 <%= row_background %> p-3 pl-6">
                <span class="absolute inset-y-2 left-2 w-px bg-gray-700"></span>
                <span class="absolute left-[5px] top-4 inline-flex h-2.5 w-2.5 rounded-full bg-cyan-400"></span>
                <div class="flex items-start justify-between gap-3">
                  <p class="text-sm text-gray-200"><%= activity_description(activity_log) %></p>
                  <span class="shrink-0 text-xs text-gray-500"><%= time_ago_in_words(activity_log.created_at) %> ago</span>
                </div>
                <div class="mt-1 text-xs">
                  <%= link_to activity_log.ticket.key, ticket_path(activity_log.ticket), class: "text-cyan-300 hover:text-cyan-200" %>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-400">No recent activity recorded.</p>
        <% end %>
      </article>
    </div>

    <aside class="space-y-4">
      <div class="rounded-2xl border border-gray-800 bg-gray-800/50 p-4">
        <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-300">Activity Summary</h3>
        <div class="space-y-3">
          <div class="rounded-xl border border-gray-700 bg-gray-900/60 p-3">
            <p class="text-xs uppercase tracking-wide text-gray-400">Tickets Created</p>
            <p class="mt-1 text-2xl font-bold text-gray-100"><%= @tickets_created_count %></p>
          </div>
          <div class="rounded-xl border border-gray-700 bg-gray-900/60 p-3">
            <p class="text-xs uppercase tracking-wide text-gray-400">Tickets Assigned</p>
            <p class="mt-1 text-2xl font-bold text-gray-100"><%= @tickets_assigned_count %></p>
          </div>
          <div class="rounded-xl border border-gray-700 bg-gray-900/60 p-3">
            <p class="text-xs uppercase tracking-wide text-gray-400">Comments Posted</p>
            <p class="mt-1 text-2xl font-bold text-gray-100"><%= @comments_count %></p>
          </div>
        </div>
      </div>

      <% if @user.admin? %>
        <div class="rounded-2xl border border-gray-800 bg-gray-800/50 p-4">
          <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-300">API Tokens</h3>
          <% if @api_tokens.any? %>
            <div class="space-y-2">
              <% @api_tokens.each do |token| %>
                <div class="rounded-lg border border-gray-700 bg-gray-900/60 p-3 text-sm">
                  <p class="font-medium text-gray-100"><%= token.name %></p>
                  <p class="mt-1 text-xs text-gray-400">
                    <%= token.last_used_at.present? ? "Last used #{time_ago_in_words(token.last_used_at)} ago" : "Never used" %>
                  </p>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-400">No API tokens created yet.</p>
          <% end %>
        </div>
      <% end %>
    </aside>
  </section>
</div>
