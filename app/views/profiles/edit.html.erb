<div class="mx-auto max-w-3xl space-y-6">
  <section>
    <h1 class="text-3xl font-bold text-white" style="font-family: 'Playfair Display', serif;">Edit Profile</h1>
    <p class="mt-2 text-sm text-gray-400">Update your public profile details used across the workspace.</p>
  </section>

  <section class="rounded-2xl border border-gray-800 bg-gray-800/60 p-6">
    <%= form_with model: @user, url: profile_path, method: :patch, class: "space-y-5" do |form| %>
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <%= form.label :first_name, class: "mb-1 block text-sm font-medium text-gray-200" %>
          <%= form.text_field :first_name, class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-gray-100 placeholder-gray-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= form.label :last_name, class: "mb-1 block text-sm font-medium text-gray-200" %>
          <%= form.text_field :last_name, class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-gray-100 placeholder-gray-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-gray-700 bg-gray-900/60 p-3">
          <p class="text-xs uppercase tracking-[0.15em] text-gray-400">Email</p>
          <p class="mt-1 text-sm font-medium text-gray-100"><%= @user.email %></p>
          <p class="mt-1 text-xs text-gray-500">Managed by authentication settings.</p>
        </div>
        <div class="rounded-xl border border-gray-700 bg-gray-900/60 p-3">
          <p class="text-xs uppercase tracking-[0.15em] text-gray-400">Role</p>
          <p class="mt-1 text-sm font-medium text-gray-100"><%= @user.role.humanize %></p>
          <p class="mt-1 text-xs text-gray-500">Role changes are admin-managed.</p>
        </div>
      </div>

      <div>
        <%= link_to "Change Password", edit_user_registration_path, class: "text-sm font-medium text-cyan-300 hover:text-cyan-200" %>
      </div>

      <div class="flex flex-wrap gap-3">
        <%= form.submit "Save Changes", class: "inline-flex rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-indigo-500" %>
        <%= link_to "Cancel", profile_path, class: "inline-flex rounded-lg border border-gray-700 bg-gray-900 px-4 py-2 text-sm font-medium text-gray-200 transition hover:bg-gray-700" %>
      </div>
    <% end %>
  </section>
</div>
