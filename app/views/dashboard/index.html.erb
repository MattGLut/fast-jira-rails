<div class="space-y-8">
  <section>
    <h1 class="text-3xl font-bold text-white" style="font-family: 'Playfair Display', serif;">Dashboard</h1>
    <p class="mt-2 text-sm text-gray-400">Operational pulse across your tickets and delivery flow.</p>
  </section>

  <section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
    <% Ticket.statuses.keys.each do |status| %>
      <div class="rounded-2xl border border-gray-800 bg-gray-800/60 p-4">
        <p class="text-xs uppercase tracking-[0.2em] text-gray-400"><%= status.humanize %></p>
        <p class="mt-2 text-3xl font-bold text-white"><%= @status_counts[status] %></p>
      </div>
    <% end %>
  </section>

  <section class="grid gap-6 xl:grid-cols-2">
    <div class="rounded-2xl border border-gray-800 bg-gray-800/50 p-4">
      <h2 class="mb-4 text-lg font-semibold text-white">Assigned to me</h2>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="text-left text-xs uppercase tracking-wide text-gray-400">
            <tr>
              <th class="pb-2">Key</th>
              <th class="pb-2">Title</th>
              <th class="pb-2">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <% @assigned_tickets.each do |ticket| %>
              <tr>
                <td class="py-2 text-gray-300"><%= ticket.key %></td>
                <td class="py-2"><%= link_to ticket.title, ticket_path(ticket), class: "text-cyan-300 hover:text-cyan-200" %></td>
                <td class="py-2"><span class="rounded-full px-2 py-1 text-xs <%= status_badge_class(ticket.status) %>"><%= ticket.status.humanize %></span></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="rounded-2xl border border-gray-800 bg-gray-800/50 p-4">
      <h2 class="mb-4 text-lg font-semibold text-white">Recent activity</h2>
      <div class="space-y-3">
        <% @recent_activity.each do |activity| %>
          <div class="rounded-xl border border-gray-700 bg-gray-900/60 p-3 text-sm">
            <p class="text-gray-200"><span class="font-semibold text-white"><%= activity.user.email %></span> <%= activity.action.humanize.downcase %></p>
            <p class="text-xs text-gray-500"><%= activity.ticket.key %> · <%= time_ago_in_words(activity.created_at) %> ago</p>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <section class="rounded-2xl border border-gray-800 bg-gray-800/50 p-4">
    <h2 class="mb-4 text-lg font-semibold text-white">Recent tickets</h2>
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="text-left text-xs uppercase tracking-wide text-gray-400">
          <tr>
            <th class="pb-2">Key</th>
            <th class="pb-2">Title</th>
            <th class="pb-2">Project</th>
            <th class="pb-2">Priority</th>
            <th class="pb-2">Updated</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <% @recent_tickets.each do |ticket| %>
            <tr>
              <td class="py-2 text-gray-300"><%= ticket.key %></td>
              <td class="py-2"><%= link_to ticket.title, ticket_path(ticket), class: "text-cyan-300 hover:text-cyan-200" %></td>
              <td class="py-2 text-gray-300"><%= ticket.project.name %></td>
              <td class="py-2"><span class="rounded-full px-2 py-1 text-xs <%= priority_badge_class(ticket.priority) %>"><%= ticket.priority.humanize %></span></td>
              <td class="py-2 text-gray-400"><%= l(ticket.updated_at, format: :short) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
