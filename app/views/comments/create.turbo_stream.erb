<%= turbo_stream.append "comments_list" do %>
  <%= render "comments/comment", comment: @comment, ticket: @ticket, show_delete: policy(@comment).destroy? %>
<% end %>

<%= turbo_stream.replace "new_comment" do %>
  <%= form_with model: [@ticket, @ticket.comments.new], class: "mt-4 space-y-2" do |f| %>
    <%= f.text_area :body, rows: 3, placeholder: "Add a comment...", class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-sm text-gray-100" %>
    <%= f.submit "Post comment", class: "rounded-lg bg-cyan-500 px-4 py-2 text-sm font-semibold text-gray-950 hover:bg-cyan-400" %>
  <% end %>
<% end %>
