<% ticket ||= comment.ticket %>
<% show_delete = local_assigns.fetch(:show_delete, false) %>

<div id="comment_<%= comment.id %>" class="rounded-xl border border-gray-700 bg-gray-900/60 p-3">
  <div class="mb-2 flex items-center justify-between text-xs text-gray-400">
    <span><%= comment.user.email %></span>
    <span><%= time_ago_in_words(comment.created_at) %> ago</span>
  </div>
  <div class="prose prose-invert prose-sm max-w-none">
    <%= render_markdown(comment.body) %>
  </div>
  <% if show_delete %>
    <div class="mt-2">
      <%= button_to "Delete", ticket_comment_path(ticket, comment), method: :delete, class: "text-xs text-red-300 hover:text-red-200" %>
    </div>
  <% end %>
</div>
