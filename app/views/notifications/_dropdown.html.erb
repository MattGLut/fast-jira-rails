<div class="relative" data-controller="dropdown">
  <button type="button"
          class="relative rounded-lg border border-gray-700 bg-gray-800 p-2 text-gray-200 hover:bg-gray-700"
          data-action="click->dropdown#toggle"
          aria-label="Notifications">
    🔔
    <% if unread_count.to_i.positive? %>
      <span class="absolute -right-1 -top-1 inline-flex h-4 min-w-4 items-center justify-center rounded-full bg-red-500 px-1 text-[10px] font-semibold text-white">
        <%= unread_count %>
      </span>
    <% end %>
  </button>

  <div class="absolute right-0 z-50 mt-2 hidden w-[22rem] rounded-xl border border-gray-700 bg-gray-900 p-3 shadow-2xl shadow-black/40" data-dropdown-target="menu">
    <div class="mb-3 flex items-center justify-between">
      <h3 class="text-sm font-semibold text-white">Notifications</h3>
      <% if unread_count.to_i.positive? %>
        <%= button_to "Mark all as read", mark_all_as_read_notifications_path,
                      method: :patch,
                      class: "text-xs text-cyan-300 hover:text-cyan-200",
                      form: { data: { turbo_stream: true } } %>
      <% end %>
    </div>

    <div class="max-h-80 space-y-2 overflow-y-auto">
      <% if notifications.any? %>
        <% notifications.each do |notification| %>
          <%= render "notifications/notification", notification: notification, dom_id_value: "dropdown_#{dom_id(notification)}", show_mark_button: false %>
        <% end %>
      <% else %>
        <p class="rounded-lg border border-gray-800 bg-gray-900/70 p-3 text-sm text-gray-400">No notifications yet.</p>
      <% end %>
    </div>

    <div class="mt-3 border-t border-gray-800 pt-3 text-right">
      <%= link_to "See all notifications", notifications_path, class: "text-sm text-cyan-300 hover:text-cyan-200" %>
    </div>
  </div>
</div>
