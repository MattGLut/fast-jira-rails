<div class="space-y-4">
  <h1 class="text-2xl font-bold text-white" style="font-family: 'Playfair Display', serif;">Labels · <%= @project.name %></h1>
  <div class="space-y-2">
    <% @labels.each do |label| %>
      <div class="flex items-center gap-3 rounded-lg border border-gray-700 bg-gray-800/60 px-4 py-3">
        <span class="h-3 w-3 rounded-full" style="background: <%= label.color %>"></span>
        <span class="text-sm text-gray-200"><%= label.name %></span>
      </div>
    <% end %>
  </div>
</div>
