<div class="space-y-8">
  <section class="flex flex-wrap items-end justify-between gap-3">
    <div>
      <h1 class="text-3xl font-bold text-white" style="font-family: 'Playfair Display', serif;">🤖 AI Agent Activity</h1>
      <p class="mt-2 text-sm text-gray-400">Live operational view of autonomous agents, delivery throughput, and active execution streams.</p>
    </div>
  </section>

  <section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <div class="rounded-2xl border border-gray-800 bg-gray-800/60 p-4">
      <p class="text-xs uppercase tracking-[0.2em] text-gray-400">Active agents</p>
      <p class="mt-2 text-3xl font-bold text-white"><%= @active_agents_count %></p>
    </div>
    <div class="rounded-2xl border border-gray-800 bg-gray-800/60 p-4">
      <p class="text-xs uppercase tracking-[0.2em] text-gray-400">Tickets in progress</p>
      <p class="mt-2 text-3xl font-bold text-white"><%= @tickets_in_progress_count %></p>
    </div>
    <div class="rounded-2xl border border-gray-800 bg-gray-800/60 p-4">
      <p class="text-xs uppercase tracking-[0.2em] text-gray-400">PRs submitted today</p>
      <p class="mt-2 text-3xl font-bold text-white"><%= @prs_submitted_today %></p>
    </div>
    <div class="rounded-2xl border border-gray-800 bg-gray-800/60 p-4">
      <p class="text-xs uppercase tracking-[0.2em] text-gray-400">Comments posted today</p>
      <p class="mt-2 text-3xl font-bold text-white"><%= @comments_posted_today %></p>
    </div>
  </section>

  <section class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
    <% @agent_rows.each do |row| %>
      <% status_class = if row[:token].last_used_at.present? && row[:token].last_used_at >= 1.hour.ago
                          "bg-green-400"
                        elsif row[:token].last_used_at.present? && row[:token].last_used_at >= 24.hours.ago
                          "bg-yellow-400"
                        else
                          "bg-gray-500"
                        end %>
      <article class="group rounded-2xl border border-gray-700 bg-gray-800 p-5 shadow-lg shadow-black/20 transition hover:ring-2 hover:ring-cyan-500/40">
        <div class="flex items-start justify-between gap-3">
          <div>
            <h2 class="text-lg font-semibold text-white"><%= row[:token].name %></h2>
            <p class="text-sm text-gray-300"><%= row[:user].first_name.presence || row[:user].email %></p>
          </div>
          <span class="mt-1 inline-flex h-3 w-3 rounded-full <%= status_class %>" title="Agent status"></span>
        </div>

        <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
          <div class="rounded-lg border border-gray-700 bg-gray-900/60 p-2">
            <p class="text-xs text-gray-400">Assigned</p>
            <p class="text-lg font-semibold text-gray-100"><%= row[:assigned_count] %></p>
          </div>
          <div class="rounded-lg border border-gray-700 bg-gray-900/60 p-2">
            <p class="text-xs text-gray-400">Completed</p>
            <p class="text-lg font-semibold text-gray-100"><%= row[:completed_count] %></p>
          </div>
          <div class="rounded-lg border border-gray-700 bg-gray-900/60 p-2">
            <p class="text-xs text-gray-400">PRs</p>
            <p class="text-lg font-semibold text-gray-100"><%= row[:pr_count] %></p>
          </div>
          <div class="rounded-lg border border-gray-700 bg-gray-900/60 p-2">
            <p class="text-xs text-gray-400">Comments</p>
            <p class="text-lg font-semibold text-gray-100"><%= row[:comment_count] %></p>
          </div>
        </div>

        <p class="mt-3 text-xs text-gray-400">
          Last active:
          <span class="text-gray-300"><%= row[:last_activity_at].present? ? "#{time_ago_in_words(row[:last_activity_at])} ago" : "No activity yet" %></span>
        </p>

        <div class="mt-4 rounded-lg border border-gray-700 bg-gray-900/50 p-3">
          <p class="mb-2 text-xs uppercase tracking-wide text-gray-400">Current work</p>
          <% if row[:assigned_tickets_preview].any? %>
            <ul class="space-y-1.5 text-sm text-gray-200">
              <% row[:assigned_tickets_preview].each do |ticket| %>
                <li>
                  <%= link_to "#{ticket.key} · #{ticket.title}", ticket_path(ticket), class: "text-cyan-300 hover:text-cyan-200" %>
                </li>
              <% end %>
            </ul>
            <% if row[:assigned_tickets_remaining].positive? %>
              <p class="mt-2 text-xs text-gray-400">
                and <%= link_to row[:assigned_tickets_remaining], agent_path(row[:token]), class: "text-cyan-300 hover:text-cyan-200" %> more
              </p>
            <% end %>
          <% else %>
            <p class="text-sm text-gray-400">No active assignments.</p>
          <% end %>
        </div>

        <div class="mt-4">
          <%= link_to "View timeline", agent_path(row[:token]), class: "inline-flex items-center rounded-lg border border-cyan-400/40 px-3 py-1.5 text-sm font-medium text-cyan-200 transition hover:bg-cyan-500/10" %>
        </div>
      </article>
    <% end %>
  </section>
</div>
