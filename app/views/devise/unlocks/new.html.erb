<div class="mx-auto max-w-md rounded-2xl border border-gray-700 bg-gray-800/90 p-6 shadow-2xl shadow-black/40">
  <h2 class="mb-1 text-2xl font-semibold text-gray-100" style="font-family: 'Playfair Display', serif;">Resend unlock instructions</h2>
  <p class="mb-6 text-sm text-gray-300">We'll send unlock details to your email.</p>

  <%= form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: "mb-1 block text-sm font-medium text-gray-200" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-lg border border-gray-600 bg-gray-700 px-3 py-2 text-white focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/40" %>
    </div>

    <%= f.submit "Resend unlock instructions", class: "w-full rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700" %>
  <% end %>

  <div class="mt-5 space-y-1 text-sm text-gray-300">
    <%= render "devise/shared/links" %>
  </div>
</div>
