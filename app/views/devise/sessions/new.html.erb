<div class="mx-auto max-w-md rounded-2xl border border-gray-700 bg-gray-800/90 p-6 shadow-2xl shadow-black/40">
  <h2 class="mb-1 text-2xl font-semibold text-gray-100" style="font-family: 'Playfair Display', serif;">Welcome back</h2>
  <p class="mb-6 text-sm text-gray-300">Sign in to continue to FastJira.</p>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
    <div>
      <%= f.label :email, class: "mb-1 block text-sm font-medium text-gray-200" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-lg border border-gray-600 bg-gray-700 px-3 py-2 text-white focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/40" %>
    </div>

    <div>
      <%= f.label :password, class: "mb-1 block text-sm font-medium text-gray-200" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "w-full rounded-lg border border-gray-600 bg-gray-700 px-3 py-2 text-white focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/40" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center gap-2 text-sm text-gray-300">
        <%= f.check_box :remember_me, class: "rounded border-gray-600 bg-gray-700 text-indigo-500 focus:ring-indigo-500" %>
        <%= f.label :remember_me %>
      </div>
    <% end %>

    <%= f.submit "Log in", class: "w-full rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700" %>
  <% end %>

  <div class="mt-5 space-y-1 text-sm text-gray-300">
    <%= render "devise/shared/links" %>
  </div>
</div>
