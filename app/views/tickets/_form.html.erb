<%= form_with model: (@ticket.persisted? ? @ticket : [@ticket.project, @ticket]), class: "space-y-5 rounded-2xl border border-gray-800 bg-gray-800/50 p-6" do |f| %>
  <% if @ticket.errors.any? %>
    <div class="rounded-xl border border-red-500/40 bg-red-500/10 p-3 text-sm text-red-200">
      <%= @ticket.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "mb-1 block text-sm font-medium text-gray-200" %>
    <%= f.text_field :title, class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-gray-100 focus:border-cyan-400 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :description, class: "mb-1 block text-sm font-medium text-gray-200" %>
    <%= f.text_area :description, rows: 6, class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-gray-100 focus:border-cyan-400 focus:outline-none" %>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <div>
      <%= f.label :status, class: "mb-1 block text-sm font-medium text-gray-200" %>
      <%= f.select :status, Ticket.statuses.keys.map { |status| [status.humanize, status] }, {}, class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-gray-100" %>
    </div>

    <div>
      <%= f.label :priority, class: "mb-1 block text-sm font-medium text-gray-200" %>
      <%= f.select :priority, Ticket.priorities.keys.map { |priority| [priority.humanize, priority] }, {}, class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-gray-100" %>
    </div>

    <div>
      <%= f.label :ticket_type, class: "mb-1 block text-sm font-medium text-gray-200" %>
      <%= f.select :ticket_type, Ticket.ticket_types.keys.map { |ticket_type| [ticket_type.humanize, ticket_type] }, {}, class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-gray-100" %>
    </div>

    <div>
      <%= f.label :story_points, class: "mb-1 block text-sm font-medium text-gray-200" %>
      <%= f.select :story_points, options_for_select([["None", ""]] + Ticket::STORY_POINTS.map { |points| [points, points] }, @ticket.story_points), {}, class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-gray-100" %>
    </div>

    <div>
      <%= f.label :due_date, class: "mb-1 block text-sm font-medium text-gray-200" %>
      <%= f.date_field :due_date, class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-gray-100" %>
    </div>

    <div>
      <%= f.label :assignee_id, class: "mb-1 block text-sm font-medium text-gray-200" %>
      <%= f.collection_select :assignee_id, @project_members, :id, :email, { include_blank: "Unassigned" }, class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-gray-100" %>
    </div>
  </div>

  <div>
    <%= f.label :label_ids, "Labels", class: "mb-2 block text-sm font-medium text-gray-200" %>
    <div class="flex flex-wrap gap-2">
      <% @labels.each do |label| %>
        <label class="inline-flex items-center gap-2 rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-sm text-gray-200">
          <%= check_box_tag "ticket[label_ids][]", label.id, @ticket.label_ids.include?(label.id), class: "rounded border-gray-600 bg-gray-800 text-cyan-400" %>
          <span class="inline-block h-2 w-2 rounded-full" style="background: <%= label.color %>"></span>
          <%= label.name %>
        </label>
      <% end %>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "Cancel", (@ticket.persisted? ? ticket_path(@ticket) : board_project_path(@ticket.project)), class: "rounded-lg border border-gray-700 px-4 py-2 text-sm text-gray-300 hover:bg-gray-800" %>
    <%= f.submit class: "rounded-lg bg-cyan-500 px-4 py-2 text-sm font-semibold text-gray-950 hover:bg-cyan-400" %>
  </div>
<% end %>
