<div class="space-y-6">
  <section class="rounded-2xl border border-gray-800 bg-gray-800/50 p-6">
    <p class="text-xs uppercase tracking-[0.2em] text-cyan-300"><%= @project.key %></p>
    <h1 class="mt-2 text-3xl font-bold text-white" style="font-family: 'Playfair Display', serif;"><%= @project.name %></h1>
    <p class="mt-3 max-w-4xl text-sm text-gray-300"><%= @project.description.presence || "No project description." %></p>
    <div class="mt-5 flex flex-wrap gap-2">
      <%= link_to "Open Board", board_project_path(@project), class: "rounded-lg bg-cyan-500 px-4 py-2 text-sm font-semibold text-gray-950 hover:bg-cyan-400" %>
      <%= link_to "Settings", settings_project_path(@project), class: "rounded-lg border border-gray-700 px-4 py-2 text-sm text-gray-300 hover:bg-gray-800" %>
      <%= link_to "New Ticket", new_project_ticket_path(@project), class: "rounded-lg border border-gray-700 px-4 py-2 text-sm text-gray-300 hover:bg-gray-800" %>
    </div>
  </section>

  <section class="rounded-2xl border border-gray-800 bg-gray-800/50 p-6">
    <h2 class="mb-4 text-lg font-semibold text-white">Latest tickets</h2>
    <div class="space-y-3">
      <% @tickets.each do |ticket| %>
        <div class="rounded-xl border border-gray-700 bg-gray-900/60 p-4">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <%= link_to "#{ticket.key} · #{ticket.title}", ticket_path(ticket), class: "font-medium text-cyan-300 hover:text-cyan-200" %>
            <span class="rounded-full px-2 py-1 text-xs <%= status_badge_class(ticket.status) %>"><%= ticket.status.humanize %></span>
          </div>
        </div>
      <% end %>
    </div>
  </section>
</div>
