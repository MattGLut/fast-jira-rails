<div class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-white" style="font-family: 'Playfair Display', serif;">Projects</h1>
      <p class="text-sm text-gray-400">Choose a battlefield and track execution in real time.</p>
    </div>
    <%= link_to "New Project", new_project_path, class: "rounded-lg bg-cyan-500 px-4 py-2 text-sm font-semibold text-gray-950 hover:bg-cyan-400" %>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
    <% @projects.each do |project| %>
      <article class="rounded-2xl border border-gray-800 bg-gray-800/60 p-5 shadow-xl shadow-black/20">
        <div class="mb-3 flex items-start justify-between">
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-cyan-300"><%= project.key %></p>
            <h2 class="text-xl font-semibold text-white"><%= project.name %></h2>
          </div>
          <span class="rounded-full bg-gray-900 px-3 py-1 text-xs text-gray-300"><%= project.tickets.size %> tickets</span>
        </div>
        <p class="mb-4 line-clamp-3 text-sm text-gray-400"><%= project.description.presence || "No description yet." %></p>
        <div class="flex gap-2">
          <%= link_to "Board", board_project_path(project), class: "rounded-lg bg-cyan-500/20 px-3 py-2 text-sm text-cyan-200 hover:bg-cyan-500/30" %>
          <%= link_to "Settings", settings_project_path(project), class: "rounded-lg border border-gray-700 px-3 py-2 text-sm text-gray-300 hover:bg-gray-800" %>
        </div>
      </article>
    <% end %>
  </div>
</div>
