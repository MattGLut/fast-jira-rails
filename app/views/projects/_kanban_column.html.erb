<div class="flex min-h-[60vh] min-w-[18rem] flex-1 flex-col rounded-2xl border border-gray-800 bg-gray-800/50 p-3"
     data-status="<%= status %>">
  <div class="mb-3 flex items-center justify-between">
    <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-200"><%= title %></h3>
    <span class="rounded-full bg-gray-900 px-2 py-1 text-xs text-gray-300" id="<%= "#{status}_count" %>"><%= tickets.count %></span>
  </div>

  <div class="flex min-h-[120px] flex-1 flex-col gap-3"
       data-kanban-target="column"
       data-status="<%= status %>">
    <% tickets.each do |ticket| %>
      <%= render "tickets/card", ticket: ticket %>
    <% end %>
  </div>
</div>
