<%= form_with model: @project, class: "space-y-5 rounded-2xl border border-gray-800 bg-gray-800/50 p-6" do |f| %>
  <% if @project.errors.any? %>
    <div class="rounded-xl border border-red-500/40 bg-red-500/10 p-3 text-sm text-red-200">
      <%= @project.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "mb-1 block text-sm font-medium text-gray-200" %>
    <%= f.text_field :name, class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-gray-100 focus:border-cyan-400 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :key, class: "mb-1 block text-sm font-medium text-gray-200" %>
    <%= f.text_field :key, class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 uppercase text-gray-100 focus:border-cyan-400 focus:outline-none" %>
    <p class="mt-1 text-xs text-gray-400">2-6 uppercase letters</p>
  </div>

  <div>
    <%= f.label :description, class: "mb-1 block text-sm font-medium text-gray-200" %>
    <%= f.text_area :description, rows: 5, class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-gray-100 focus:border-cyan-400 focus:outline-none" %>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "Cancel", projects_path, class: "rounded-lg border border-gray-700 px-4 py-2 text-sm text-gray-300 hover:bg-gray-800" %>
    <%= f.submit class: "rounded-lg bg-cyan-500 px-4 py-2 text-sm font-semibold text-gray-950 hover:bg-cyan-400" %>
  </div>
<% end %>
