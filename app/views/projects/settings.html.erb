<div class="space-y-6">
  <div>
    <p class="text-xs uppercase tracking-[0.2em] text-cyan-300"><%= @project.key %></p>
    <h1 class="text-3xl font-bold text-white" style="font-family: 'Playfair Display', serif;">Project Settings</h1>
  </div>

  <div class="grid gap-6 xl:grid-cols-2">
    <section class="rounded-2xl border border-gray-800 bg-gray-800/50 p-5">
      <h2 class="mb-4 text-lg font-semibold text-white">Members</h2>
      <%= form_with model: [@project, ProjectMembership.new], url: project_memberships_path(@project), class: "mb-4 grid gap-2 sm:grid-cols-3" do |f| %>
        <%= f.collection_select :user_id, User.order(:first_name, :last_name), :id, :email, {}, class: "rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-sm text-gray-100 sm:col-span-2" %>
        <%= f.select :role, ProjectMembership.roles.keys.map { |role| [role.humanize, role] }, {}, class: "rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-sm text-gray-100" %>
        <%= f.submit "Add", class: "rounded-lg bg-cyan-500 px-4 py-2 text-sm font-semibold text-gray-950 hover:bg-cyan-400 sm:col-span-3" %>
      <% end %>

      <div class="space-y-2">
        <% @memberships.each do |membership| %>
          <div class="flex items-center justify-between rounded-lg border border-gray-700 bg-gray-900/60 p-3 text-sm">
            <div>
              <p class="font-medium text-gray-100"><%= membership.user.email %></p>
              <p class="text-xs text-gray-400"><%= membership.role.humanize %></p>
            </div>
            <%= button_to "Remove", project_membership_path(@project, membership), method: :delete, class: "rounded-lg border border-red-500/40 px-3 py-1.5 text-xs text-red-200 hover:bg-red-500/10" %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="rounded-2xl border border-gray-800 bg-gray-800/50 p-5">
      <h2 class="mb-4 text-lg font-semibold text-white">Labels</h2>
      <%= form_with model: [@project, @label], class: "mb-4 grid gap-2 sm:grid-cols-3" do |f| %>
        <%= f.text_field :name, placeholder: "Label name", class: "rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-sm text-gray-100 sm:col-span-2" %>
        <%= f.color_field :color, class: "h-10 w-full rounded-lg border border-gray-700 bg-gray-900" %>
        <%= f.submit "Create Label", class: "rounded-lg bg-cyan-500 px-4 py-2 text-sm font-semibold text-gray-950 hover:bg-cyan-400 sm:col-span-3" %>
      <% end %>

      <div class="space-y-2">
        <% @labels.each do |label| %>
          <div class="flex items-center justify-between rounded-lg border border-gray-700 bg-gray-900/60 p-3 text-sm">
            <div class="flex items-center gap-3">
              <span class="h-3 w-3 rounded-full" style="background: <%= label.color %>"></span>
              <span class="text-gray-100"><%= label.name %></span>
            </div>
            <%= button_to "Delete", project_label_path(@project, label), method: :delete, class: "rounded-lg border border-red-500/40 px-3 py-1.5 text-xs text-red-200 hover:bg-red-500/10" %>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</div>
