<div class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div>
      <p class="text-xs uppercase tracking-[0.2em] text-cyan-300"><%= @project.key %></p>
      <h1 class="text-3xl font-bold text-white" style="font-family: 'Playfair Display', serif;"><%= @project.name %> Board</h1>
    </div>
    <div class="flex gap-2">
      <%= link_to "New Ticket", new_project_ticket_path(@project), class: "rounded-lg bg-cyan-500 px-4 py-2 text-sm font-semibold text-gray-950 hover:bg-cyan-400" %>
      <%= link_to "Settings", settings_project_path(@project), class: "rounded-lg border border-gray-700 px-4 py-2 text-sm text-gray-300 hover:bg-gray-800" %>
    </div>
  </div>

  <%= turbo_frame_tag "kanban_board" do %>
    <%= render "board_content" %>
  <% end %>
</div>
