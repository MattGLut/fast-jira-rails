<div class="fixed inset-0 z-40 hidden bg-black/70 lg:hidden" data-sidebar-target="overlay" data-action="click->sidebar#close"></div>

<aside class="fixed inset-y-0 left-0 z-50 w-72 -translate-x-full border-r border-gray-800 bg-gray-950 px-4 py-6 transition-transform duration-200 lg:translate-x-0"
       data-sidebar-target="panel">
  <div class="mb-8 flex items-center justify-between">
    <h2 class="text-2xl font-bold tracking-wide text-white" style="font-family: 'Playfair Display', serif;">FastJira</h2>
    <button type="button" class="rounded-lg p-2 text-gray-400 hover:bg-gray-800 lg:hidden" data-action="click->sidebar#close">✕</button>
  </div>

  <nav class="space-y-2">
    <%= nav_link("Dashboard", root_path, icon: "🏠") %>
    <%= nav_link("Projects", projects_path, icon: "📁", active_paths: ["/projects"]) %>
    <%= nav_link("My Tickets", my_tickets_path, icon: "🧾") %>
    <%= nav_link("AI Agents", agents_path, icon: "🤖") %>
  </nav>

  <div class="mt-8">
    <p class="mb-3 px-2 text-xs font-semibold uppercase tracking-[0.2em] text-gray-400">Projects</p>
    <div class="max-h-[45vh] space-y-1 overflow-y-auto pr-1">
      <% @sidebar_projects.to_a.each do |project| %>
        <%= nav_link("#{project.key} · #{project.name}", board_project_path(project), icon: "▣") %>
      <% end %>
    </div>
  </div>

  <div class="absolute bottom-6 left-4 right-4 rounded-xl border border-gray-800 bg-gray-900 p-3">
    <%= link_to profile_path, class: "mb-3 block rounded-lg p-1 transition hover:bg-gray-800/80" do %>
      <p class="text-sm font-semibold text-white"><%= [current_user.first_name, current_user.last_name].compact.join(" ").presence || current_user.email %></p>
      <p class="text-xs uppercase tracking-wide text-gray-400"><%= current_user.role.humanize %></p>
    <% end %>
    <%= button_to "Sign out", destroy_user_session_path, method: :delete,
                  class: "w-full rounded-lg bg-gray-800 px-3 py-2 text-sm font-medium text-gray-200 hover:bg-gray-700" %>
  </div>
</aside>
